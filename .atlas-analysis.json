  "keyFeatures": [
    "Multi-platform social media scraping (Instagram, TikTok, Threads, X)",
    "Gender-based profile filtering",
    "Multi-tenant job management with base isolation",
    "Campaign creation and tracking",
    "Automated VA distribution (80 tables × 180 profiles)",
    "Airtable synchronization",
    "Real-time statistics and progress tracking",
    "Supabase database with RLS"
  ],
  "publicApiSurface": [
    "POST /api/scrape-followers - Scrape Instagram followers from source accounts",
    "POST /api/ingest - Ingest profiles into database",
    "POST /api/daily-selection - Create campaign and select profiles",
    "POST /api/distribute/{campaign_id} - Distribute profiles to VA tables",
    "POST /api/airtable-sync/{campaign_id} - Sync profiles to Airtable",
    "POST /api/cleanup - Cleanup 7-day old campaigns",
    "createScrapingJob() - Create new scraping job",
    "getActiveJob() - Get active scraping job",
    "getJobStatistics() - Get job statistics",
    "apiRequest() - Make API request with base_id injection"
  ]
